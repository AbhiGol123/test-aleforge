---
import Layout from "@layouts/Layout.astro";

const {url} = Astro.request;
const pathname = new URL(url).pathname;
---

<Layout title="404 - Page Not Found">
    <div class="error-page-wrapper global-padding">
        <div>
            <div class="container-large">
                <div class="flex justify-between items-center py-3">
                    <div class="logo">
                        <a href="/">
                            <div
                                class="h-10 w-40 bg-contain bg-no-repeat bg-left"
                                style={{backgroundImage: "var(--logo)"}}
                                role="img"
                                aria-label="Aleforge Logo"
                            >
                            </div>
                        </a>
                    </div>
                    <div class="nav-links hide-on-mobile flex gap-8">
                        <button class="button-primary" data-i18n="404Page.getStarted">Get Started</button>
                    </div>
                </div>
            </div>
        </div>

        <main class="error-container">
            <div class="error-content">
                <!-- Center Image -->
                <div class="error-illustration"></div>

                <h2 class="title-main" style="font-size:36px" data-i18n="404Page.pageNotFound">Page Not Found</h2>
                <p class="subtitle pt-1" data-i18n="404Page.looksLikePageWentOffline">Looks like this page went offline or never existed in the first place.</p>

                <div class="actions-flex pt-5">
                    <a href="/" class="button-primary" data-i18n="404Page.goBackHome">Go Back Home</a>
                    <a href="/game-server" class="button-secondary" data-i18n="404Page.viewGameServers">View Game Servers</a>
                </div>
            </div>
        </main>
    </div>
</Layout>

<style>
    .error-page-wrapper {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow-x: hidden;
    }

    @media (max-width: 768px) {
        .error-page-wrapper {
            min-height: 20vh;
        }
    }

    .error-container {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px 0;
    }

    .error-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .title-main {
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 700;
        color: var(--text-primary);
        line-height: 1.1;
        margin: 0;
    }

    .subtitle {
        margin: 0;
    }

    .error-illustration {
        position: relative;
        width: 100%;
        max-width: 800px;
        height: 350px;
        margin-bottom: -20px;

        background-image: var(--not-found-img);
        background-size: contain;
        background-repeat: no-repeat;
        background-position: center;

        z-index: 1;
    }
    .error-illustration::before {
        content: "";
        position: absolute;
        inset: -35%;
        background-image: var(--not-found-img-glow);
        background-size: contain;
        background-repeat: no-repeat;
        background-position: center;

        opacity: 0.6; /* control glow strength */
        filter: blur(10px); /* optional extra softness */
        z-index: -1;
        pointer-events: none;
    }

    .actions-flex {
        display: flex;
        justify-content: center;
        gap: 24px;
    }

    @media (max-width: 768px) {
        .hide-on-mobile {
            display: none;
        }

        .error-illustration {
            width: 100%;
            max-width: 400px;
            height: 300px;
            background-size: contain;
        }
    }

    @media (max-width: 400px) {
        .actions-flex {
            flex-direction: column;
            width: 100%;
            padding-left: 20px;
            padding-right: 20px;
            gap: 16px;
        }

        .actions-flex a {
            width: 100%;
            text-align: center;
        }

        .error-illustration {
            width: 100%;
            height: 200px;
        }

        .title-main {
            font-size: 28px !important;
        }
    }
</style>
