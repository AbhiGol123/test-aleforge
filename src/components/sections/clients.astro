---
const brands = [
  {
    name: "Stripe",
    logo: "../../assets/images/icons/General/trustedBy/Stripe.webp"
  },
  {
    name: "PayPal",
    logo: "../../assets/images/icons/General/trustedBy/Pay Pal.webp"
  },
  {
    name: "Discord",
    logo: "../../assets/images/icons/General/trustedBy/Discord.webp"
  },
  {
    name: "DigitalOcean",
    logo: "../../assets/images/icons/General/trustedBy/DigitalOcean.webp"
  },
  {
    name: "OVHcloud",
    logo: "../../assets/images/icons/General/trustedBy/OVHcloud.webp"
  },
  {
    name: "Docker",
    logo: "../../assets/images/icons/General/trustedBy/docker.webp"
  }
];
---

<section class="trusted-section">
  <div class="global-padding">
    <div class="container-large mx-auto text-center">
      <h2 data-i18n="clientsComponent.grandFoundryPlatform">The Grand Foundry Platform</h2>
      <p class="subtitle">One powerful plan.<strong data-i18n="clientsComponent.40SupportedGames"> 40+ supported games </strong> Switch anytime at <strong data-i18n="clientsComponent.noExtraCost">no extra cost.</strong> </p>
      <div class="logo-carousel mt-[40px]">
        <div class="logo-track">
          {
            brands.concat(brands).map((brand) => (
              <div class="logo-item" title={brand.name}>
                <img src={brand.logo} alt={brand.name} />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use "../../styles/core/mixins" as *;

  .trusted-section {
    padding: 2rem 0;
    overflow: hidden;

    @include md {
      padding: 3rem 0;
    }
  }
  .logo-carousel {
    position: relative;
    overflow: hidden;
    width: 100%;
    display: flex;
    align-items: center;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .logo-track {
    display: flex;
    width: max-content;
    animation: scroll 20s linear infinite;
    align-items: center;
    gap: 3rem;

    @include md {
      gap: 5rem;
      animation-duration: 25s;
    }

    &:hover {
      animation-play-state: paused;
    }
  }

  .logo-item {
    flex: 0 0 auto;
    filter: grayscale(100%) brightness(0.6);
    opacity: 0.6;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;

    img {
      height: 32px;
      width: auto;
      object-fit: contain;
      transition: all 0.3s ease;
    }
    &:hover {
      filter: grayscale(0%) brightness(1);
      opacity: 1;
      transform: scale(1.1);
    }
  }
  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
