---
const features = [
  {
    icon: "inventory_2",
    text: "Customizable / Upgradable"
  },
  {
    icon: "security",
    text: "DDoS Protection"
  },
  {
    icon: "wifi",
    text: "99.99% Uptime SLA"
  },
  {
    icon: "call",
    text: "24/7 Enterprise Support"
  }
];
---

<section class="header-section">
  <div class="section-padding global-padding">
    <div class="container-large">
      <div class="content_wrapper mx-auto text-center flex flex-col gap-[12px]">
        <h1>Dedicated Servers</h1>
        <p class="max-w-3xl mx-auto subtitle">
          Experience High-Performance Dedicated Servers With Affordable Pricing, Full DDoS Protection, And 24/7
          Enterprise Support All With No Long-Term Contracts.
        </p>
        <div class="flex flex-wrap gap-[16px] text-white justify-center max-w-[900px] mx-auto">
          {
            features.map((item) => (
              <div class="flex items-center gap-3">
                <span
                  class="material-icons  bg-[#FFFFFF]/6 rounded-[10px] p-[8px]"
                  style="color: var(--accent); font-size:20px"
                >
                  {item.icon}
                </span>
                <p class="">{item.text}</p>
              </div>
            ))
          }
        </div>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-[20px]">
          <a href="#dedicatedServerPricing" class="button-primary"> View Servers </a>
          <a href="/contactUs" class="button-secondary"> Get Started </a>
        </div>
      </div>
    </div>
  </div>
</section>
