
<section class="support-section">
  <div class="section-padding global-padding">
    <div class="container-large mx-auto px-4">
      <div
        class="support-card relative rounded-3xl border border-white/10 bg-[#0C0D18]/12 p-8 md:p-16 text-center shadow-2xl shadow-[var(--shadow-card)]"
      >
        <div class="absolute top-0 left-0 right-0 flex justify-center pointer-events-none z-10">
          <div
            class="w-full h-64 bg-contain bg-top bg-no-repeat opacity-60"
            style={{
              backgroundImage: "var(--dedicated-server-ellipse)"
            }}
            role="img"
            aria-label="Decorative ellipse"
          >
          </div>
        </div>

        <!-- Content -->
        <div class="max-w-3xl mx-auto mb-12">
          <span class="overline" data-i18n="supportComponent.needHelp">Need Help?</span>
          <h2 class=" mb-6 " data-i18n="supportComponent.supportWizardsHere247">Our Support Wizards Are Here 24/7.</h2>
          <p class="leading-relaxed max-w-3xl mx-auto mt-2" style="font-size: 20px;" data-i18n="supportComponent.whetherItSSetupScaling">
            Whether It's Setup, Scaling, Or Troubleshooting Our Support Team Is Always Ready To Assist Through Discord,
            Live Chat, Or Support Tickets.
          </p>
        </div>

        <!-- Action Buttons Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          <!-- Discord Button -->
          <a
            href="#"
            class="action-btn group flex items-center gap-4 p-2 rounded-xl border border-[var(--border-light)] bg-[#FFFFFF]/3 hover:bg-[var(--bg-card-hover)] hover:border-[var(--accent)] transition-all duration-300 text-left"
          >
            <div
              class="icon-box w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300"
            >
              <img
                src="../../assets/images/icons/General/hosting/CTA/discord.webp"
                alt="Discord"
                class="w-9 h-9 object-contain"
              />
            </div>
            <div>
              <h3 class="text-white" , style="font-size: 20px;" data-i18n="supportComponent.joinDiscord">Join Discord</h3>
              <p class="text-[var(--text-muted)]" , style="font-size: 16px;" data-i18n="supportComponent.connectCommunity">Connect with our community</p>
            </div>
          </a>

          <!-- Live Chat Button -->
          <a
            href="#"
            class="action-btn group flex items-center gap-4 p-2 rounded-xl border border-[var(--border-light)] bg-[#FFFFFF]/3 hover:bg-[var(--bg-card-hover)] hover:border-[var(--accent)] transition-all duration-300 text-left"
          >
            <div
              class="icon-box w-12 h-12 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300"
            >
              <img
                src="../../assets/images/icons/General/hosting/CTA/chat.webp"
                alt="Discord"
                class="w-9 h-9 object-contain"
              />
            </div>
            <div>
              <h3 class="text-white" style="font-size: 20px;" data-i18n="supportComponent.liveChat">Live Chat</h3>
              <p class="text-[var(--text-muted)]" style="font-size: 16px;" data-i18n="supportComponent.talkSupportWizardNow">Talk to a support wizard now</p>
            </div>
          </a>

          <!-- Ticket Button -->
          <a
            href="#"
            class="action-btn group flex items-center gap-4 p-2 rounded-xl border border-[var(--border-light)] bg-[#FFFFFF]/3 hover:bg-[var(--bg-card-hover)] hover:border-[var(--accent)] transition-all duration-300 text-left"
          >
            <div
              class="icon-box w-12 h-12 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300"
            >
              <img
                src="../../assets/images/icons/General/hosting/CTA/file.webp"
                alt="Discord"
                class="w-9 h-9 object-contain"
              />
            </div>
            <div>
              <h3 class="text-white" style="font-size: 20px;" data-i18n="supportComponent.openTicket">Open a Ticket</h3>
              <p class="text-[var(--text-muted)]" style="font-size: 16px;" data-i18n="supportComponent.247TechnicalSupport">24/7 technical support</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .support-section {
    /* background-color: var(--bg-body); */
  }
</style>
