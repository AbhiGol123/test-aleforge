---
const features = [
    "Enterprise Hardware",
    "Enhanced Network Security",
    "99.9% Uptime",
    "Robust Security",
    "SSH Access",
    "Managed Backups",
    "Customizable Configurations",
    "Fast Deployment",
    "Enterprise-Grade Storage",
    "Scalable Resources",
    "Scalable Resources",
    "Remote Management Options",
    "Dedicated Bandwidth",
    "High Performance Hardware",
    "Advanced Monitoring Tools",
    "Redundant Power Supply",
    "Web Panel Integrations",
    "Geographically Diverse Locations",
    "Compliance-Ready Solutions",
    "Competitive Pricing"
];
---

<section class="server-features">
    <div class="section-padding global-padding">
        <div class="container-large">
            <div
                class="feature-card relative overflow-hidden rounded-3xl border border-white/10 bg-[#0C0D18]/12 backdrop-blur-xs p-8 md:p-16 text-center shadow-2xl shadow-[var(--shadow-card)]"
            >
                <!-- Header -->
                <div class="max-w-3xl mx-auto mb-12">
                    <span class="overline italic block" style="color: var(--accent)" data-i18n="serverFeatureComponent.speedPowerValue">Speed. Power. Value.</span>
                    <h2 class="mb-4" data-i18n="serverFeatureComponent.powerPerformanceReliabilityBuilt">Power, Performance, And Reliability Built In.</h2>
                    <p class="max-w-3xl mx-auto" data-i18n="serverFeatureComponent.everyDedicatedServerEquippedEnterprise">
                        Every Dedicated Server Is Equipped With Enterprise Hardware, Robust Security, And Scalable
                        Resources Delivering Unbeatable Performance, Uptime, And Control.
                    </p>
                </div>

                <!-- Features Grid -->
                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-4 text-center md:text-left max-w-6xl mx-auto"
                >
                    {
                        features.map((feature, index) => (
                            <>
                                <div class="flex items-center justify-center md:justify-start gap-3 group">
                                    <div class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-[#0974E1]/4 transition-all duration-300 group-hover:scale-110">
                                        <div
                                            class="w-5 h-5 bg-contain bg-no-repeat bg-center"
                                            style="background-image: var(--right-tick);"
                                        >
                                        </div>
                                    </div>
                                    <span class="text-[var(--text-primary)] md:text-base font-regular group-hover:text-[var(--accent)] transition-colors duration-300", style="font-size: 20px;">
                                        {feature}
                                    </span>
                                </div>
                                {(index === 6 || index === 13) && (
                                    <div class="w-full h-px bg-white/10 my-2 md:hidden" />
                                )}
                            </>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .server-features {
        /* background-color: var(--bg-body); */
    }
</style>
