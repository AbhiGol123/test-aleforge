---
import FilterSection from "./FilterSection.astro";
const { locations } = Astro.props;

const COUNTRY_OPTIONS = [
  { value: "us", label: "United States" },
  { value: "au", label: "Australia" },
  { value: "ca", label: "Canada" },
  { value: "eu", label: "Europe" },
  { value: "in", label: "India" },
  { value: "sg", label: "Singapore" },
  { value: "gb", label: "United Kingdom" },
];
---

<div class="rounded-2xl border border-white/10 bg-[var(--bg-body)] pb-6">
  <!-- Header -->
  <div class="flex items-center justify-between bg-[#282931] px-4 py-3 mb-4 rounded-t-2xl">
    <h3 class="text-lg font-medium text-white" data-i18n="filterspanelComponent.filters">Filters</h3>
    <button id="resetFilters" class="rounded-full bg-[var(--accent)] px-4 py-1 text-sm text-white" data-i18n="filterspanelComponent.reset">
      Reset
    </button>
  </div>
  <div class="p-4 gap-4 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-1">
    <!-- CPU TYPE -->
    <FilterSection title="CPU Type">
      <div class="flex flex-wrap gap-2 ">
        <button class="filter-btn active" data-cpu-filter="all" data-i18n="filterspanelComponent.all">ALL</button>
        <button class="filter-btn" data-cpu-filter="intel" data-i18n="filterspanelComponent.intel">Intel</button>
        <button class="filter-btn" data-cpu-filter="amd" data-i18n="filterspanelComponent.amd">AMD</button>
      </div>
    </FilterSection>

    <!-- CORES -->
    <FilterSection title="Cores">
      <div class="flex justify-between text-sm text-white/70 mb-2">
        <span data-i18n="filterspanelComponent.cores">Cores:</span>
        <span>4–64</span>
      </div>

      <div class="multi-range" data-filter-min="minCores" data-filter-max="maxCores" data-step="2">
        <div class="range-track-base"></div>
        <div class="range-track"></div>
        <input type="range" min="4" max="64" value="4" class="range range-min" />
        <input type="range" min="4" max="64" value="64" class="range range-max" />
        <span class="range-badge badge-min">04</span>
        <span class="range-badge badge-max">64</span>
      </div>
    </FilterSection>

    <!-- MEMORY -->
    <FilterSection title="Memory">
      <div class="flex justify-between text-xs text-white/70 mb-2">
        <span data-i18n="filterspanelComponent.memory">Memory:</span>
        <span data-i18n="filterspanelComponent.16gb1024gb">16GB–1024GB</span>
      </div>
      <div
        class="multi-range"
        data-filter-min="minMemory"
        data-filter-max="maxMemory"
        data-step="16"
      >
        <div class="range-track-base"></div>
        <div class="range-track"></div>
        <input type="range" min="16" max="1024" value="16" class="range range-min" />
        <input type="range" min="16" max="1024" value="1024" class="range range-max" />
        <span class="range-badge badge-min" data-i18n="filterspanelComponent.16gb">16GB</span>
        <span class="range-badge badge-max" data-i18n="filterspanelComponent.1024gb">1024GB</span>
      </div>
    </FilterSection>

    <!-- STORAGE TYPE -->
    <FilterSection title="Storage Type">
      <div class="flex flex-wrap gap-2">
        <button class="filter-btn active" data-storage-filter="all" data-i18n="filterspanelComponent.all">ALL</button>
        <button class="filter-btn" data-storage-filter="nvme" data-i18n="filterspanelComponent.nvme">NVMe</button>
        <button class="filter-btn" data-storage-filter="ssd" data-i18n="filterspanelComponent.ssd">SSD</button>
        <button class="filter-btn" data-storage-filter="hdd" data-i18n="filterspanelComponent.hdd">HDD</button>
      </div>
    </FilterSection>

    <!-- LOCATION -->
    <FilterSection title="Location">
      <select id="locationSelect" class="select">
        <option value="all" data-i18n="filterspanelComponent.allLocations">All Locations</option>

        {
          COUNTRY_OPTIONS.filter((opt) => locations.includes(opt.value)).map((opt) => (
            <option value={opt.value}>{opt.label}</option>
          ))
        }
      </select>
    </FilterSection>

    <!-- PRICE -->
    <FilterSection title="Price">
      <div class="flex justify-between text-xs text-white/70 mb-2">
        <span data-i18n="filterspanelComponent.price">Price:</span>
        <span>$0–$1000</span>
      </div>
      <div class="multi-range" data-filter-min="minPrice" data-filter-max="maxPrice" data-step="10">
        <div class="range-track-base"></div>
        <div class="range-track"></div>
        <input type="range" min="0" max="1000" value="0" class="range range-min" />
        <input type="range" min="0" max="1000" value="1000" class="range range-max" />
        <span class="range-badge badge-min">$0</span>
        <span class="range-badge badge-max">$1000</span>
      </div>
    </FilterSection>
  </div>

  <style>
    .filter-btn {
      padding: 0.35rem 0.75rem;
      border-radius: 0.375rem;
      font-size: 15px;
      background: rgba(255, 255, 255, 0.08);
      color: rgba(255, 255, 255, 0.7);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .filter-btn.active {
      /* background: var(--accent); */
      color: var(--accent);
      border: 1px solid var(--accent);
    }

    .range {
      width: 100%;
      appearance: none;
      height: 6px;
      border-radius: 999px;
      background: #1f2937;
    }

    .range::-webkit-slider-thumb {
      appearance: none;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--accent);
    }

    .range.purple::-webkit-slider-thumb {
      background: var(--accent);
    }

    .badge {
      background: var(--accent);
      color: white;
      padding: 0.15rem 0.4rem;
      border-radius: 0.25rem;
      font-size: 0.7rem;
      margin-top: 10px;
    }

    .select {
      width: 100%;
      background: var(--bg-card);
      border-radius: 0.375rem;
      padding: 0.8rem;
      color: white;
      font-size: 16px;
      border: 1px solid var(--border-light);
    }

    /* multi range */
    .multi-range {
      position: relative;
      height: 40px;
    }

    .multi-range input[type="range"] {
      position: absolute;
      width: 100%;
      pointer-events: none;
      appearance: none;
      height: 20px;
      background: transparent;
      z-index: 3;
    }

    .multi-range input[type="range"]::-webkit-slider-thumb {
      pointer-events: auto;
      appearance: none;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--accent);
    }
    .range-track-base {
      position: absolute;
      top: 7px;
      width: 100%;
      height: 6px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.25); /* empty visible */
      z-index: 1;
    }

    .range-track {
      position: absolute;
      top: 7px;
      height: 6px;
      border-radius: 999px;
      background: var(--accent);
      z-index: 2;
    }

    .range-badge {
      position: absolute;

      top: 24px;
      transform: translateX(-50%);
      background: var(--accent);
      color: white;
      font-size: 0.7rem;
      padding: 0.15rem 0.45rem;
      border-radius: 0.25rem;
      pointer-events: none;
      z-index: 4;
    }
  </style>
</div>
