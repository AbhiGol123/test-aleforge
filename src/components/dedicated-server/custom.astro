<section class="custom-section">
    <div class="section-padding global-padding">
        <div class="container-large mx-auto">
            <div
                class="relative overflow-hidden rounded-[2rem] md:rounded-[3rem] bg-[#0C0D18]/12 border border-white/10 px-6 py-16 md:px-12 md:py-24 text-center shadow-2xl"
            >
                <!-- Background Gradient Effect -->
                <div
                    class="absolute top-0 right-0 -mt-20 -mr-20 h-[300px] w-[300px] rounded-full blur-[100px] pointer-events-none"
                    style="background-color: var(--accent); opacity: 0.2;"
                >
                </div>
                <div
                    class="absolute bottom-0 left-0 -mb-20 -ml-20 h-[300px] w-[300px] rounded-full blur-[100px] pointer-events-none"
                    style="background-color: var(--accent); opacity: 0.2;"
                >
                </div>

                <!-- Content -->
                <div class="relative z-10 max-w-4xl mx-auto">
                    <h2 class="mb-6 leading-tight">
                        Looking For Something More Custom?<br class="hidden md:block" />
                        We Have Solutions Available To You!
                    </h2>
                    <p class="subtitle mb-10 max-w-2xl mx-auto" data-i18n="dedicatedServerCustomComponent.behaviouralHereSWhenIt">
                        The Behavioural And To Here's When It And Have Target Should Texting.
                    </p>

                    <div class="flex flex-col min-[440px]:flex-row items-center justify-center gap-4">
                        <!-- Contact Us Button -->
                        <a href="/contactUs" class="button-primary" data-i18n="dedicatedServerCustomComponent.contactUs"> Contact Us </a>

                        <!-- Chat with Us Button -->
                        <button class="button-secondary flex items-center gap-2">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path>
                                <path d="M8 12h.01"></path>
                                <path d="M12 12h.01"></path>
                                <path d="M16 12h.01"></path>
                            </svg>
                            <span data-i18n="dedicatedServerCustomComponent.chatUs">Chat with Us</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
