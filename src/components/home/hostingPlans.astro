---
const hostingPlans = [
{
icon: "../../assets/images/icons/General/home/hosting/home-web.webp",
title: "Web Hosting",
desc: "Easy cPanel hosting with full control, storage, and bandwidth. Perfect for small sites.",
price: "$2.95/mo",
link: "/web-hosting",
},
{
icon: "../../assets/images/icons/General/home/hosting/home-wp.webp",
title: "WordPress Hosting",
desc: "Enjoy speed, security, and automatic updates with built-in CDN.",
price: "$7.99/mo",
link: "/wordpress-hosting",
},
{
icon: "../../assets/images/icons/General/home/hosting/home-server.webp",
title: "Dedicated Servers",
desc: "High-performance servers built for speed, stability, and growth.",
price: "$58.99/mo",
link: "/dedicated-servers",
},
];
---
<section class="relative" id="hostingPlans">
  <div class="global-padding section-padding">
    <div class="container-large">
      <div class="flex flex-col md:flex-row md:justify-between md:items-end  mb-10">
        <h2 class="w-full md:w-[500px] text-center md:text-left" data-i18n="hostingplansComponent.hostingScalesVision"> Hosting That Scales With Your Vision </h2>
        <p class="subtitle md:text-right text-center w-full md:w-[400px]" data-i18n="hostingplansComponent.fastSecureReliableHostingDesigned"> Fast, Secure, And Reliable Hosting Designed
          To Power Your Online Success. </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
        hostingPlans.map((plan, index) => (
        <div class={`relative group border-2 border-[#FFFFFF]/10 rounded-2xl p-6 text-left transition-all duration-300
          backdrop-blur-xs bg-[#505265]/10 hover:-translate-y-2 flex flex-col h-full ${index===2
          ? 'md:col-span-2 lg:col-span-1 md:max-w-md md:mx-auto lg:max-w-none lg:mx-0' : '' }`}>
          <div
            class="flex items-center justify-center w-[74px] h-[74px] rounded-full bg-[#505265]/40 mb-5  mx-auto md:mx-0">
            <img src={plan.icon} alt="" class="w-[32px] h-[32px] text-white" />
          </div>
          <h3 class="mb-2 text-center md:text-left text-[26px] font-medium">{plan.title}</h3>
          <p class="mb-6 flex-grow text-center md:text-left ">{plan.desc}</p>
          <div class="border-t border-[var(--border-light)] mb-5" />
          <div class="flex items-center justify-between mt-auto">
            <div>
              <p class=" text-white">
                {plan.price}
              </p>
              <p class="text-[var(--text-muted)]" style="font-size: 12px;" data-i18n="hostingplansComponent.starting">
                Starting At
              </p>
            </div>
            <a href={plan.link} class="button-primary" data-i18n="hostingplansComponent.getStarted">
              Get started
            </a>
          </div>
        </div>
        ))
        }
      </div>
    </div>
  </div>
</section>