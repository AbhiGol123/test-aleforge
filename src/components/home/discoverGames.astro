---
import {urlFor} from "src/lib/sanityImage";
import {getGamesWithMinPrice} from "src/services/gameService";
const games = await getGamesWithMinPrice();
const topGames = games.slice(0, 2);
console.log(topGames);
const bottomGames = games.slice(2, 5);
---

<section class="discover_games text-[var(--text-primary)]">
  <div class="global-padding section-padding">
    <div class="container-large">
      <div class="title-wrapper">
        <h2 data-i18n="discovergamesComponent.discoverTrendingGames">Discover Trending Games</h2>
        <p class="subtitle">
          Check Out Some Of The Most Popular Game Servers You Can Instantly Deploy With AleForge.
          <a href="#" class="text-[var(--accent)] hover:underline"> Hosting Plans Start At Just $X.XX Per Slot. </a>
        </p>
      </div>

      <!-- Top Row (2 cards) -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 mb-4 md:mb-6 mt-[60px]">
        {
          topGames.map((game: any) => (
            <div class="group border border-2 border-[var(--border-light)] rounded-[16px] overflow-hidden  transition-all duration-300  p-4 md:p-5 bg-[#191A2B]/20 backdrop-blur-xs">
              <div class="relative game-image-wrapper rounded-[10px]">
                <img
                  src={game.coverImg ? urlFor(game.coverImg) : "https://placehold.co/600x800?text=No+Image"}
                  alt={game.name}
                  class="game-img transition-transform duration-500 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[var(--bg-body)]/80 via-transparent" />
              </div>
              <div class="mt-4 md:mt-5">
                <h3>{game.name}</h3>
                <p class="small mb-4">
                  Starting at <span class="accent text-[16px]">{game.minPrice}</span>
                </p>
                <a href={`/${game.name.replace(/\s+/g, "-")}`} class="button-secondary text-white text-sm" data-i18n="discovergamesComponent.orderNow">
                  Order Now
                </a>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Bottom Row (3 cards) -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {
          bottomGames.map((game: any) => (
            <div class="group border border-2 border-[var(--border-light)] rounded-[16px] overflow-hidden transition-all duration-300  p-4 md:p-5 bg-[#191A2B]/20 backdrop-blur-xs">
              <div class="relative h-[180px] md:h-[280px] overflow-hidden rounded-[10px]">
                <img
                  src={game.coverImg ? urlFor(game.coverImg) : "https://placehold.co/600x800?text=No+Image"}
                  alt={game.name}
                  class=" transition-transform duration-500 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[var(--bg-body)]/80 via-transparent" />
              </div>
              <div class="mt-4 md:mt-5">
                <h3 class="mb-1">{game.name}</h3>
                <p class="small mb-4">
                  Starting at <span class="accent text-[16px]">{game.minPrice}</span>
                </p>
                <a href={`/${game.name.replace(/\s+/g, "-")}`} class="button-secondary text-white text-sm" data-i18n="discovergamesComponent.orderNow">
                  Order Now
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .game-image-wrapper {
    width: 100%;
    aspect-ratio: 16 / 9; /* 🔥 consistent cards */
    overflow: hidden;
    border-radius: 14px;
  }

  .game-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center; /* or: top */
    transition: transform 0.5s ease;
  }

  .group:hover .game-img {
    transform: scale(1.05);
  }
</style>
