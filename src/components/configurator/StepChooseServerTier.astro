<div id="tier-step" data-step="tier" class="config-step bg-[var(--configurator-bg)] border border-[#FFFFFF]/12 rounded-2xl p-4 md:p-6">
  <div class="flex items-start gap-4 mb-2">
    <div
      class="step-badge  flex-shrink-0 w-12 h-12 text-[34px] rounded-lg bg-[var(--configurator-text)] text-white flex items-center justify-center"
    >
      2
    </div>
    <div class="flex-1">
      <h4 class="text-white text-[26px]" data-i18n="stepchooseservertierComponent.chooseServerTier">Choose Your Server Tier</h4>
      <p class="font-[200]" style="font-size: 16px;" data-i18n="stepchooseservertierComponent.chooseServerTierSelectPerformance">
        Choose Your Server Tier | Select the performance level that best fits your gameplay needs and budget.
      </p>
    </div>
  </div>

  <div class="border-b border-[#D9D9D9]/12 mb-4"></div>

  <!-- Server Tier Selection -->
  <div>
    <div class="flex items-center justify-between mb-4">
      <p class="text-white text-md" data-i18n="stepchooseservertierComponent.serverTierSelection">Server Tier Selection:</p>
      <div class="flex justify-end mt-3">
        <button id="open-tier-modal" class="text-[var(--accent)] text-md underline hover:opacity-80" data-i18n="stepchooseservertierComponent.learnMoreAboutTiers">
          Learn more about tiers
        </button>
      </div>
    </div>

    <!-- ✅ Dynamic Tier Buttons -->
    <div class="tier-selection-grid">
      {
        [
          {
            id: "budget",
            label: "Budget",
            subtitle: "Entry Level",
            tooltip: "Best for starting out and small communities."
          },
          {
            id: "standard",
            label: "Standard",
            subtitle: "Recommended",
            tooltip: "Upgraded performance for vanilla servers."
          },
          {
            id: "premium",
            label: "Premium",
            subtitle: "Maximum Power",
            tooltip: "Top-tier performance for large modded servers."
          }
        ].map((tier) => (
          <button
            class="server-tier-btn relative flex flex-col items-center justify-center bg-[var(--configurator-inner-button-disselected-bg)] gap-1 rounded-lg py-3 text-md font-medium transition-all text-white"
            data-tier={tier.id}
          >
            <div class="flex items-center gap-2">
              <span>{tier.label}</span>

              <span class="info-icon relative group">
                i
                <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-48 p-2 bg-[var(--server-tier-popup-bg)] border border-white/12 rounded-lg text-xs text-center text-[var(--text-secondary)] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-10 pointer-events-none shadow-xl">
                  {tier.tooltip}
                </div>
              </span>
            </div>

            <div class="text-sm mt-1 opacity-80">{tier.subtitle}</div>
          </button>
        ))
      }
    </div>
  </div>
</div>

<!-- 🔍 Tier Comparison Modal -->
<div id="tier-modal" class="fixed inset-0 hidden z-[9999] bg-black/60 backdrop-blur-sm">
  <div
    class="bg-[var(--configurator-bg)] rounded-xl max-w-5xl w-[95%] p-6 fixed"
    style="top:30%; left:50%; transform:translate(-50%, -50%);"
  >
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-2xl font-semibold" data-i18n="stepchooseservertierComponent.serverTierComparison">Server Tier Comparison</h3>
      <button id="tier-modal-close" class="text-white text-xl hover:opacity-70"> ✕ </button>
    </div>

    <!-- Dynamic Modal Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm"></div>
  </div>
</div>

<style>
  .tier-selection-grid {
    background: var(--card-bg);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0.75rem;
    padding: 0.25rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;

    @media (max-width: 550px) {
      grid-template-columns: 1fr;
    }
  }

  .info-icon {
    width: 16px;
    height: 16px;

    display: inline-flex;
    align-items: center;
    justify-content: center;

    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.4);

    font-size: 10px;
    font-weight: 300;
    opacity: 0.8;
  }
</style>

<script>
  // @ts-nocheck
  import {configStore, setTier} from "/src/stores/configuratorStore";
  import {priceStore, recalculatePrice} from "/src/stores/priceStore";

  // console.log("[Tier] Step mounted");

  const buttons = document.querySelectorAll(".server-tier-btn");
  const tierModal = document.getElementById("tier-modal");
  const modalGrid = tierModal.querySelector(".grid");
  const openTierModalBtn = document.getElementById("open-tier-modal");
  const closeTierModalBtn = document.getElementById("tier-modal-close");

  let hasBudget = true;

  /* -------------------------
     APPLY VISIBILITY RULES
  --------------------------*/
  function applyTierVisibility() {
    buttons.forEach((btn) => {
      const tier = btn.dataset.tier;

      if (tier === "budget" && !hasBudget) {
        btn.style.display = "none";
        btn.disabled = true;
      } else {
        btn.style.display = "";
        btn.disabled = false;
      }
    });
  }

  /* -------------------------
     Sync UI from Store
  --------------------------*/
  function syncUI() {
    const state = configStore.get();
    if (!state) return;

    const {selectedTier} = state;

    buttons.forEach((btn) => {
      const active = btn.dataset.tier === selectedTier;

      btn.classList.toggle("bg-[var(--configurator-inner-button-selected-bg)]", active);
      btn.classList.toggle("bg-[var(--configurator-inner-button-disselected-bg)]", !active);
    });

    // console.log("[Tier] UI synced:", selectedTier);
  }

  /* -------------------------
     Dynamic Modal Rendering
  --------------------------*/
  function renderTierModal() {
    const price = priceStore.get();
    if (!price) return;

    const tiers = [
      {
        id: "budget",
        title: "Budget",
        price: price.budget?.monthly,
        features: ["Small communities", "Lower CPU priority", "Lightweight plugins"]
      },
      {
        id: "standard",
        title: "Standard",
        price: price.standard?.monthly,
        features: ["Balanced performance", "Moderate plugins", "Stable servers"]
      },
      {
        id: "premium",
        title: "Premium",
        price: price.premium?.monthly,
        features: ["Maximum performance", "Heavy modpacks", "High concurrency"]
      }
    ].filter((t) => hasBudget || t.id !== "budget");

    modalGrid.innerHTML = tiers
      .map(
        (tier) => `
        <div class="border border-white/10 rounded-lg p-4">
          <h4 class="text-lg font-semibold mb-2">${tier.title}</h4>
          <p class="text-sm mb-2">$${tier.price || "—"} / month</p>
          <ul class="space-y-2 opacity-90">
            ${tier.features.map((f) => `<li>✔ ${f}</li>`).join("")}
          </ul>
        </div>
      `
      )
      .join("");
  }

  /* -------------------------
     STORE SUBSCRIBE
  --------------------------*/
  configStore.subscribe((state) => {
    if (!state) return;

    hasBudget = state.hasBudget === true || state.hasBudget === "true";

    applyTierVisibility();

    // 🚫 Force fallback if budget blocked
    if (!hasBudget && state.selectedTier === "budget") {
      // console.log("🚫 Budget blocked → switching to standard");
      setTier("standard");
      recalculatePrice();
    }

    syncUI();
  });

  /* -------------------------
     Initialize Once
  --------------------------*/
  const initial = configStore.get();

  if (initial?.hasBudget === false || initial?.hasBudget === "false") {
    hasBudget = false;
  }

  applyTierVisibility();

  if (!initial?.selectedTier) {
    const defaultTier = hasBudget ? "budget" : "standard";
    setTier(defaultTier);
    recalculatePrice();
  }

  /* -------------------------
     Click Events
  --------------------------*/
  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const tier = btn.dataset.tier;

      if (tier === "budget" && !hasBudget) return;

      console.log("[Tier] Clicked:", tier);
      setTier(tier);
      recalculatePrice(); // ✅ Fix price update
    });
  });

  /* -------------------------
     Modal Logic
  --------------------------*/
  openTierModalBtn?.addEventListener("click", () => {
    renderTierModal();
    tierModal.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  });

  closeTierModalBtn?.addEventListener("click", closeTierModal);

  tierModal?.addEventListener("click", (e) => {
    if (e.target === tierModal) closeTierModal();
  });

  function closeTierModal() {
    tierModal.classList.add("hidden");
    document.body.style.overflow = "";
  }
</script>
