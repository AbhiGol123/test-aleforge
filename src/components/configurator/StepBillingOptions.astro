---
import PromoCode from "./PromoCode.astro";
---

<div id="billing-step" data-step="billing" class="config-step bg-[var(--configurator-bg)] border border-[#FFFFFF]/12 rounded-2xl p-4 md:p-6">
  <div class="flex items-start gap-4 mb-2">
    <div
      class="step-badge  flex-shrink-0 w-12 h-12 text-[34px] rounded-lg bg-[var(--configurator-text)] text-white flex items-center justify-center"
    >
      5
    </div>
    <div class="flex-1">
      <h4 class="text-white text-[26px]" data-i18n="stepbillingoptionsComponent.billingOptions">Billing Options</h4>
      <p class="font-[200]" style="font-size: 16px;" data-i18n="stepbillingoptionsComponent.chooseBillingPeriodWhichFir">
        Choose a billing period which fir your needs, and apply any promo codes you have.
      </p>
    </div>
  </div>

  <div class="border-b mb-4 border-white/10"></div>

  <!-- Billing Plans -->
  <div>
    <p class="text-white text-sm mb-4" data-i18n="stepbillingoptionsComponent.selectPlans">Select Plans :</p>
    <div class="billing-options-grid">
      <button
        class="billing-btn relative group flex flex-col items-center justify-center rounded-lg py-3 transition-all bg-[var(--configurator-inner-button-disselected-bg)] text-white"
        data-period="monthly"
        data-active="true"
      >
        <div class="font-bold text-md" data-i18n="stepbillingoptionsComponent.monthly">Monthly</div>
        <div class="text-sm mt-1 opacity-80" data-i18n="stepbillingoptionsComponent.00Gb">$.00 / GB</div>
      </button>

      <button
        class="billing-btn relative group flex flex-col items-center justify-center rounded-lg py-3 transition-all bg-[var(--configurator-inner-button-disselected-bg)]"
        data-period="quarterly"
        data-active="false"
      >
        <div class="font-bold text-md" data-i18n="stepbillingoptionsComponent.quarterly">Quarterly</div>
        <div class="flex items-center gap-2 mt-1">
          <span class="text-sm opacity-80" data-i18n="stepbillingoptionsComponent.270Gb">$2.70/GB</span>
          <span class="text-[12px] bg-[var(--inner-card-bg)] text-white px-1.5 py-0.5 rounded font-bold" data-i18n="stepbillingoptionsComponent.10Off">10% OFF</span>
        </div>
      </button>

      <button
        class="billing-btn relative group flex flex-col items-center justify-center rounded-lg py-3 transition-all bg-[var(--configurator-inner-button-disselected-bg)]"
        data-period="semi_annual"
        data-active="false"
      >
        <div class="font-bold text-md" data-i18n="stepbillingoptionsComponent.semiAnnual">Semi_annual</div>
        <div class="flex items-center gap-2 mt-1">
          <span class="text-sm opacity-80" data-i18n="stepbillingoptionsComponent.255Gb">$2.55/GB</span>
          <span class="text-[12px] bg-[var(--inner-card-bg)] text-white px-1.5 py-0.5 rounded font-bold" data-i18n="stepbillingoptionsComponent.15Off">15% OFF</span>
        </div>
      </button>

      <button
        class="billing-btn relative group flex flex-col items-center justify-center rounded-lg py-3 transition-all bg-[var(--configurator-inner-button-disselected-bg)]"
        data-period="annually"
        data-active="false"
      >
        <div class="font-bold text-md" data-i18n="stepbillingoptionsComponent.annually">Annually</div>
        <div class="flex items-center gap-2 mt-1">
          <span class="text-sm opacity-80" data-i18n="stepbillingoptionsComponent.240Gb">$2.40/GB</span>
          <span class="text-[12px] bg-[var(--inner-card-bg)] text-white px-1.5 py-0.5 rounded font-bold" data-i18n="stepbillingoptionsComponent.20Off">20% OFF</span>
        </div>
      </button>
    </div>

    <!-- Promo Code -->
    <PromoCode />
  </div>
</div>

<style>
  .billing-options-grid {
    background: var(--card-bg);
    //border: 1px solid var(--configurator-inner-button-border);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0.75rem;
    padding: 0.25rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.5rem;

    @media (max-width: 950px) {
      grid-template-columns: 1fr;
    }
  }

  .billing-btn {
    border: 1px solid transparent;
    transition: all 0.2s ease;
  }

  /* ✅ ACTIVE STATE */
  .billing-btn[data-active="true"] {
    background: var(--configurator-inner-button-selected-bg);
  }

  /* Optional hover polish */
  .billing-btn:hover {
    filter: brightness(1.1);
  }
</style>

<script>
  // @ts-nocheck
  import {priceStore} from "/src/stores/priceStore";
  import {setPeriod} from "/src/stores/configuratorStore";

  // console.log("[Billing] Mounted");

  const buttons = document.querySelectorAll(".billing-btn");

  let currentPrice = null;

  /* -------------------------
     Update UI
  ------------------------- */
  function renderPrices() {
    if (!currentPrice) return;

    console.log("[Billing] Price update:", currentPrice);

    buttons.forEach((btn) => {
      const period = btn.dataset.period;
      const priceEl = btn.querySelector(".text-sm");
      if (!priceEl) return;

      let value = 0;

      if (period === "monthly") value = currentPrice.monthly;
      if (period === "quarterly") value = currentPrice.quarterly;
      if (period === "semi_annual") value = currentPrice.semiAnnual;
      if (period === "annually") value = currentPrice.annually;

      priceEl.textContent = `$${value.toFixed(2)} / month`;
    });
  }

  /* -------------------------
     Subscribe to priceStore
  ------------------------- */
  priceStore.subscribe((price) => {
    currentPrice = price;
    renderPrices();
  });

  /* -------------------------
     Click Handling
  ------------------------- */
  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const period = btn.dataset.period;

      buttons.forEach((b) => (b.dataset.active = "false"));
      btn.dataset.active = "true";

      console.log("[Billing] Selected:", period);
      setPeriod(period);
    });
  });
</script>
