---
const reviews = [
    {
        name: "DirtysoFTW",
        platform: "trustpilot",
        rating: 5,
        text: "Lorem ipsum dolor sit amet consectetur. Sagittis nibh dictum consectetur sem risus. Facilisis posuere amet accumsan eget faucibus consectetur mi.",
        link: "more"
    },
    {
        name: "Robert H",
        platform: "google",
        rating: 5,
        text: "Lorem ipsum dolor sit amet consectetur. Sagittis nibh dictum consectetur sem risus. Facilisis posuere amet accumsan eget faucibus consectetur mi.",
        link: "more"
    },
    {
        name: "DirtysoFTW",
        platform: "google",
        rating: 5,
        text: "Lorem ipsum dolor sit amet consectetur. Sagittis nibh dictum consectetur sem risus. Facilisis posuere amet accumsan eget faucibus consectetur mi.",
        link: "more"
    }
];
---

<section class="rating-section">
    <div class="section-padding global-padding">
    <div class="container-large">

        <!-- Trustpilot Header -->
        <div class="text-center mb-1">
            <h2 class="mb-5" data-i18n="ratingComponent.ratedExcellent">We are Rated Excellent</h2>
            <div class="flex justify-center gap-1 mb-3 mt-4">
                <img src="../../assets/images/pages/hosting/wordPress-hosting/Frame 2147226696.webp" alt="Trustpilot Rating" class="max-w-[300px]" />
            </div>
        </div>

        <!-- Decorative Line -->
        <div class="relative mb-7">
            <svg class="w-full" height="2" viewBox="0 0 1200 2" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line x1="0" y1="1" x2="1200" y2="1" stroke="url(#gradient)" stroke-width="2"/>
                <defs>
                    <linearGradient id="gradient" x1="0" y1="0" x2="1200" y2="0">
                        <stop offset="0%" stop-color="var(--border-light)" stop-opacity="0"/>
                        <stop offset="50%" stop-color="var(--accent)"/>
                        <stop offset="100%" stop-color="var(--border-light)" stop-opacity="0"/>
                    </linearGradient>
                </defs>
            </svg>
        </div>

        <!-- Reviews Grid -->
        <div class="reviews-scroll-container flex overflow-x-auto snap-x snap-mandatory md:grid lg:grid-cols-3 gap-8 pb-4 md:pb-0">
            {reviews.map((review) => (
                <div class="min-w-[85%] lg:min-w-0 snap-center text-center bg-[#FFFFFF] rounded-2xl p-6 border border-[var(--border-light)]">
                    <!-- Star Rating -->
                    <div class="flex justify-center gap-1 mb-4">
                        {[...Array(review.rating)].map(() => (
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="#FCBF02">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                            </svg>
                        ))}
                    </div>

                    <!-- Review Text -->
                    <h5 class="text-[#3D3D3F] text-[18px] leading-relaxed mb-4">
                        {review.text}... <a href="#" class="text-[#1A1A1B] border-b border-[#1A1A1B] hover:underline">{review.link}</a>
                    </h5>

                    <!-- Reviewer Info -->
                    <div class="flex flex-col items-center justify-center gap-1">
                        <h5 class="text-[#1A1A1B] font-medium text-[16px]">{review.name}</h5>
                        <div class="flex items-center gap-1">
                        {review.platform === "trustpilot" ? (
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="#00B67A">
                                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                            </svg>
                        ) : (
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                            </svg>
                        )}
                        <span class="text-[#3D3D3F] text-xs">{review.platform === "trustpilot" ? "Trustpilot" : "Google"}</span>
                        </div>
                    </div>
                </div>
            ))}
        </div>

        <!-- Bottom Decorative Line -->
        <div class="relative mt-12">
            <svg class="w-full" height="2" viewBox="0 0 1200 2" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line x1="0" y1="1" x2="1200" y2="1" stroke="url(#gradient2)" stroke-width="2"/>
                <defs>
                    <linearGradient id="gradient2" x1="0" y1="0" x2="1200" y2="0">
                        <stop offset="0%" stop-color="var(--border-light)" stop-opacity="0"/>
                        <stop offset="50%" stop-color="var(--accent)"/>
                        <stop offset="100%" stop-color="var(--border-light)" stop-opacity="0"/>
                    </linearGradient>
                </defs>
            </svg>
        </div>
    </div>
    </div>
</section>

<style>
    .reviews-scroll-container::-webkit-scrollbar {
        height: 6px;
    }
    .reviews-scroll-container::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 3px;
    }
    .reviews-scroll-container::-webkit-scrollbar-thumb {
        background: white;
        border-radius: 3px;
    }
</style>

