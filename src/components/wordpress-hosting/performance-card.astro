---
// Performance Card Component
---

<section class="performance-card-section">
    <div class="section-padding global-padding">
        <div class="container-large">
            <div class="relative">
                <!-- Performance Card -->
                <div
                    class="relative overflow-hidden rounded-3xl bg-[#0C0D18]/12 p-8 md:p-12 lg:p-16 text-center border border-white/10"
                >
                    <!-- Header -->
                    <div class="mb-10">
                        <span class="overline text-center" style="color: var(--accent) !important;" data-i18n="performanceCardComponent.speedPowerValue">
                            Speed. Power. Value.
                        </span>
                        <h2 class="mb-4 text-center" data-i18n="performanceCardComponent.performanceSpeaksItself">Performance That Speaks For Itself</h2>
                        <p class="subtitle max-w-3xl mx-auto text-center" data-i18n="performanceCardComponent.experienceUnmatchedReliabilitySpeedOptimized">
                            Experience Unmatched Reliability And Speed Optimized For Gamers Who Demand The Best
                            Performance At The Best Price.
                        </p>
                    </div>

                    <!-- Stats Grid -->
                    <div class="grid md:grid-cols-3 gap-8 md:gap-10 max-w-5xl mx-auto">
                        <!-- Stat 1 -->
                        <div class="text-center">
                            <div class="text-[50px] font-bold text-white">23%</div>
                            <div class="flex items-center justify-center gap-2">
                                <h5 class="text-[var(--text-muted)] text-[18px]" data-i18n="performanceCardComponent.morePerformancePerDollar">More Performance Per Dollar</h5>
                                <svg
                                    class="w-4 h-4 text-[var(--text-muted)] cursor-help"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M12 16v-4m0-4h.01"></path>
                                </svg>
                            </div>
                        </div>

                        <!-- Stat 2 -->
                        <div class="text-center">
                            <div class="text-[50px] font-bold text-white" data-i18n="performanceCardComponent.25Gbit">25 Gbit</div>
                            <div class="flex items-center justify-center gap-2">
                                <h5 class="text-[var(--text-muted)] text-[18px]" data-i18n="performanceCardComponent.networkCapacity">Network Capacity</h5>
                                <svg
                                    class="w-4 h-4 text-[var(--text-muted)] cursor-help"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M12 16v-4m0-4h.01"></path>
                                </svg>
                            </div>
                        </div>

                        <!-- Stat 3 -->
                        <div class="text-center">
                            <div class="text-[50px] font-bold text-white">20%</div>
                            <div class="flex items-center justify-center gap-2">
                                <h5 class="text-[var(--text-muted)] text-[18px]" data-i18n="performanceCardComponent.fasterLoadingTimes">Faster Loading Times</h5>
                                <svg
                                    class="w-4 h-4 text-[var(--text-muted)] cursor-help"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <circle cx="12" cy="12" r="10" stroke-width="2"></circle>
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M12 16v-4m0-4h.01"></path>
                                </svg>
                            </div>
                        </div>
                    </div>

                    <!-- Bottom Decoration -->
                    <div class="absolute bottom-0 left-0 right-0 flex justify-center pointer-events-none">
                        <div
                            class="w-full h-64 bg-contain bg-bottom bg-no-repeat opacity-60"
                            style={{
                                backgroundImage: "var(--wordpress-ellipse)"
                            }}
                            role="img"
                            aria-label="Decorative ellipse"
                        >
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
