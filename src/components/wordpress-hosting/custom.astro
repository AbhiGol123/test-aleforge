<section class="custom-section">
    <div class="section-padding global-padding">
        <div class="container-large mx-auto">
            <div
                class="relative overflow-hidden rounded-[2rem] md:rounded-[3rem] bg-[#0C0D18]/12 border border-white/10 px-6 py-16 md:px-12 md:py-24 text-center shadow-2xl">
                <!-- Background Gradient Effect -->
                <div class="absolute top-0 right-0 -mt-20 -mr-20 h-[300px] w-[300px] rounded-full blur-[100px] pointer-events-none"
                    style="background-color: var(--accent); opacity: 0.2;">
                </div>
                <div class="absolute bottom-0 left-0 -mb-20 -ml-20 h-[300px] w-[300px] rounded-full blur-[100px] pointer-events-none"
                    style="background-color: var(--accent); opacity: 0.2;">
                </div>
                <!-- Content -->
                <div class="relative z-10 max-w-4xl mx-auto">
                    <span class="overline" style="color: var(--accent);" data-i18n="customComponent.customSolutionsAvailable">Custom Solutions Available</span>
                    <h2 class="mb-6" data-i18n="customComponent.needSomethingMoreCustom">Need Something More Custom?</h2>
                    <p class="subtitle mb-10 max-w-2xl mx-auto" data-i18n="customComponent.notSeeingPlanFitsNeeds">
